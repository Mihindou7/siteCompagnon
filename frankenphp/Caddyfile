{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

{$SERVER_NAME:localhost} {
	log {
		# Redact the authorization query parameter that can be set by Mercure
		format filter {
			request>uri query {
				replace authorization REDACTED
			}
		}
	}

	vars root "/app/public"

	# Compress responses for better performance
	encode zstd br gzip

	# Execute PHP files in the current directory and any subdirectory
	# See https://frankenphp.dev/docs/config/#php-threads
	php_server
}
